# OCI Auth
OCI_USER=ocid1.user.oc1..<YOUR_USER_OCID>
OCI_FINGERPRINT=<YOUR_KEY_FINGERPRINT>
OCI_TENANCY=ocid1.tenancy.oc1..<YOUR_TENANCY_OCID>
OCI_REGION=eu-frankfurt-1
OCI_KEY_FILE=/home/admincsp/graphiti_fixed_test/Configurations/oci/oci_api_key.pem
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..<YOUR_COMPARTMENT_OCID>

# OCI Models
OCI_EMBED_MODEL=cohere.embed-v4.0
OCI_EMBED_REGION=us-chicago-1
OCI_VISION_MODEL=google.gemini-2.5-pro
OCI_VISION_REGION=eu-frankfurt-1
OCI_GROUPING_MODEL=google.gemini-2.5-flash
OCI_GROUPING_REGION=eu-frankfurt-1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=docs_oci_ingested_azadea

# S3 (OCI Object Storage)
